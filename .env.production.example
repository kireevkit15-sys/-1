# === Database ===
# connection_limit: 20 for 100+ concurrent users (Prisma uses one pool per service instance)
# pool_timeout: 30s — max time to wait for a free connection before erroring
DATABASE_URL=postgresql://razum:CHANGE_ME@postgres:5432/razum?schema=public&connection_limit=20&pool_timeout=30
DATABASE_DIRECT_URL=postgresql://razum:CHANGE_ME@postgres:5432/razum?schema=public
DB_USER=razum
DB_PASSWORD=CHANGE_ME
DB_NAME=razum
# Slow query logging threshold (ms) — queries slower than this are logged as warnings
DB_SLOW_QUERY_MS=100

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# === JWT ===
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=CHANGE_ME

# === AI ===
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# === App ===
NODE_ENV=production
API_PORT=3001
FRONTEND_URL=https://razum.app
CORS_ORIGIN=https://razum.app

# === Sentry ===
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
