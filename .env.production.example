# ========================================================================
# РАЗУМ — production environment template.
# Скопируй в .env.production и заполни. НЕ коммитить .env.production!
#
# Генерация секретов:
#   openssl rand -base64 48     # JWT_SECRET, COOKIE_SECRET
#   openssl rand -base64 32     # пароли БД/Redis
#
# Ротация секретов: см. docs/SECRETS_ROTATION.md
# ========================================================================

# === Runtime =============================================================
NODE_ENV=production
LOG_LEVEL=info                         # trace|debug|info|warn|error

# === Domain ==============================================================
# Меняй на реальный домен перед запуском.
APP_DOMAIN=razum.app
FRONTEND_URL=https://razum.app
API_PUBLIC_URL=https://razum.app/api
CORS_ORIGIN=https://razum.app

# === Database (PostgreSQL) ==============================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=razum
DB_PASSWORD=__CHANGE_ME__
DB_NAME=razum
# connection_limit=20 на инстанс API (Prisma pool)
DATABASE_URL=postgresql://razum:__CHANGE_ME__@postgres:5432/razum?schema=public&connection_limit=20&pool_timeout=30
DATABASE_DIRECT_URL=postgresql://razum:__CHANGE_ME__@postgres:5432/razum?schema=public
DB_SLOW_QUERY_MS=100

# === Redis ===============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=__CHANGE_ME__
REDIS_URL=redis://:__CHANGE_ME__@redis:6379

# === JWT / Auth ==========================================================
JWT_SECRET=__CHANGE_ME_base64_48_bytes__
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECRET=__CHANGE_ME_base64_48_bytes__

# === Telegram Bot ========================================================
TELEGRAM_BOT_TOKEN=__CHANGE_ME__
TELEGRAM_BOT_USERNAME=razum_app_bot
TELEGRAM_WEBHOOK_SECRET=__CHANGE_ME_random_32__

# === AI (Anthropic Claude) ==============================================
ANTHROPIC_API_KEY=sk-ant-__CHANGE_ME__
AI_MODEL_DIALOG=claude-haiku-4-5-20251001
AI_MODEL_GENERATION=claude-sonnet-4-6
AI_DAILY_BUDGET_USD=50

# === Sentry ==============================================================
SENTRY_DSN_API=https://__CHANGE_ME__@sentry.io/__ID__
SENTRY_DSN_WEB=https://__CHANGE_ME__@sentry.io/__ID__
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=                         # подставляется в CI из git sha

# === Backups → S3 ========================================================
RAZUM_S3_BUCKET=razum-backups
RAZUM_S3_PREFIX=prod
RAZUM_S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=__CHANGE_ME__
AWS_SECRET_ACCESS_KEY=__CHANGE_ME__
BACKUP_RETENTION_DAYS=30
BACKUP_CRON="0 3 * * *"                 # каждый день в 03:00 UTC

# === Let's Encrypt =======================================================
LE_EMAIL=ops@razum.app

# === Launch flags ========================================================
BETA_MODE=true                           # требует invite-код при регистрации
INVITE_CODE_REQUIRED=true
MAINTENANCE_MODE=false

# === Ports (внутренние, наружу не выставляются) =========================
API_PORT=3001
WEB_PORT=3000
