# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
API_PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/razum?schema=public
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/razum?schema=public

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-me
REFRESH_TOKEN_EXPIRES_IN=30d

# ──────────────────────────────────────────────
# OAuth (optional)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ──────────────────────────────────────────────
# Telegram Bot
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_WEBHOOK_URL=
WEB_URL=http://localhost:3000

# ──────────────────────────────────────────────
# AI / LLM
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────
# Object Storage (S3-compatible)
# ──────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=razum-uploads
S3_REGION=us-east-1

# ──────────────────────────────────────────────
# Email (SMTP)
# ──────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@razum.local

# ──────────────────────────────────────────────
# Logging / Observability
# ──────────────────────────────────────────────
LOG_LEVEL=debug
SENTRY_DSN=
