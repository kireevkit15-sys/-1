// ─────────────────────────────────────────────
//  РАЗУМ — Prisma Schema (PostgreSQL)
// ─────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ── Enums ────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Branch {
  STRATEGY
  LOGIC
  ERUDITION
  RHETORIC
  INTUITION
}

enum Difficulty {
  BRONZE
  SILVER
  GOLD
}

enum BattleStatus {
  WAITING
  ACTIVE
  COMPLETED
  ABANDONED
}

enum BattleMode {
  SIEGE
  SPARRING
}

enum DefenseType {
  ACCEPT
  DISPUTE
  COUNTER
}

enum FeedbackType {
  LIKE
  DISLIKE
  REPORT
}

enum AchievementCategory {
  BATTLE
  LEARNING
  STREAK
  SOCIAL
  BRANCH
}

// ── User ─────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  telegramId     BigInt?  @unique
  telegramChatId BigInt?  @unique
  email          String?  @unique
  passwordHash String?
  name         String
  avatarUrl    String?
  role         Role     @default(USER)
  onboardingCompleted Boolean @default(false)
  referralCode   String   @unique @default(uuid())
  deletedAt      DateTime?
  createdAt    DateTime @default(now())

  stats          UserStats?
  battlesAsP1    Battle[]             @relation("player1")
  battlesAsP2    Battle[]             @relation("player2")
  wonBattles     Battle[]             @relation("winner")
  battleRounds   BattleRound[]
  moduleProgress    UserModuleProgress[]
  aiDialogues       AiDialogue[]
  questionFeedbacks QuestionFeedback[]
  achievements      UserAchievement[]
  referralsMade     Referral[]           @relation("referrer")
  referralsReceived Referral[]           @relation("invitee")
  analyticsEvents   AnalyticsEvent[]
  dailyChallenges   DailyChallenge[]
  warmupResults     WarmupResult[]
  pushSubscriptions PushSubscription[]
  aiTokenUsage      AiTokenUsage[]
  seasonRewards     SeasonReward[]
  tournamentEntries TournamentParticipant[]
  bans              UserBan[]
  campaignProgress  UserCampaignProgress[]
  feedState         UserFeedState?

  @@map("users")
}

// ── UserStats ────────────────────────────────

model UserStats {
  userId         String   @id @db.Uuid
  logicXp        Int      @default(0)
  eruditionXp    Int      @default(0)
  strategyXp     Int      @default(0)
  rhetoricXp     Int      @default(0)
  intuitionXp    Int      @default(0)
  rating         Int      @default(1000)
  // Per-branch ELO ratings
  logicRating    Int      @default(1000)
  eruditionRating Int     @default(1000)
  strategyRating Int      @default(1000)
  rhetoricRating Int      @default(1000)
  intuitionRating Int     @default(1000)
  streakDays     Int      @default(0)
  streakDate     DateTime? @db.Date
  thinkerClass   String?  // STRATEGIST, PHILOSOPHER, SCHOLAR, COMMANDER, VISIONARY, SAGE
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([rating(sort: Desc)])
  @@index([streakDays(sort: Desc)])
  @@map("user_stats")
}

// ── Season ───────────────────────────────────

model Season {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   // "Сезон 1 — Апрель 2026"
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  rewards SeasonReward[]

  @@index([isActive])
  @@index([endDate])
  @@map("seasons")
}

model SeasonReward {
  id         String   @id @default(uuid()) @db.Uuid
  seasonId   String   @db.Uuid
  userId     String   @db.Uuid
  rank       Int      // 1-10
  rating     Int      // rating snapshot at season end
  totalXp    Int      // XP snapshot at season end
  xpReward   Int      @default(0) // bonus XP awarded
  createdAt  DateTime @default(now())

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId, rank])
  @@map("season_rewards")
}

// ── Question ─────────────────────────────────

model Question {
  id             String     @id @default(uuid()) @db.Uuid
  category       String
  branch         Branch
  difficulty     Difficulty
  text           String
  options        Json       // JSON array of 4 strings
  correctIndex   Int        @db.SmallInt
  explanation    String
  statPrimary    String
  statSecondary  String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())

  // BC9: Answer statistics for adaptive difficulty
  totalAnswers   Int        @default(0)
  correctAnswers Int        @default(0)
  avgTimeTakenMs Int?       // Average time to answer in ms
  lastCalibratedAt DateTime? // When difficulty was last auto-adjusted

  // B14.6: Tags
  tags         String[]   @default([])

  // B19.6: A/B testing
  variantOf    String?    @db.Uuid
  variantLabel String?

  battleRounds BattleRound[]
  feedbacks    QuestionFeedback[]
  originalQuestion Question? @relation("variants", fields: [variantOf], references: [id], onDelete: SetNull)
  variants     Question[]   @relation("variants")

  @@index([branch])
  @@index([difficulty])
  @@index([category])
  @@index([isActive])
  @@index([branch, difficulty, isActive])
  @@index([branch, difficulty, category, isActive])
  @@index([tags], type: Gin)
  @@map("questions")
}

// ── QuestionFeedback ────────────────────────────

model QuestionFeedback {
  id         String       @id @default(uuid()) @db.Uuid
  questionId String       @db.Uuid
  userId     String       @db.Uuid
  type       FeedbackType
  reason     String?      // For reports: "incorrect_answer", "unclear_question", "offensive", "other"
  comment    String?      // Optional user comment
  createdAt  DateTime     @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId, type])
  @@index([questionId])
  @@index([userId])
  @@map("question_feedbacks")
}

// ── Battle ───────────────────────────────────

model Battle {
  id           String       @id @default(uuid()) @db.Uuid
  player1Id    String       @db.Uuid
  player2Id    String?      @db.Uuid
  status       BattleStatus @default(WAITING)
  mode         BattleMode   @default(SIEGE)
  category     String?
  state        Json         @default("{}")
  winnerId     String?      @db.Uuid
  player1Score Int          @default(0)
  player2Score Int          @default(0)
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime     @default(now())

  player1 User  @relation("player1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 User? @relation("player2", fields: [player2Id], references: [id], onDelete: SetNull)
  winner  User? @relation("winner", fields: [winnerId], references: [id], onDelete: SetNull)

  rounds BattleRound[]

  @@index([player1Id, status])
  @@index([player2Id, status])
  @@index([status])
  @@index([createdAt])
  @@index([endedAt])
  @@index([winnerId])
  @@map("battles")
}

// ── BattleRound ──────────────────────────────

model BattleRound {
  id           String      @id @default(uuid()) @db.Uuid
  battleId     String      @db.Uuid
  roundNumber  Int         @db.SmallInt
  attackerId   String      @db.Uuid
  questionId   String      @db.Uuid
  branch       Branch?
  difficulty   Difficulty
  answerIndex  Int?        @db.SmallInt
  isCorrect    Boolean?
  defenseType  DefenseType?
  timeTakenMs  Int?
  points       Int         @default(0)

  battle   Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  attacker User     @relation(fields: [attackerId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@index([battleId])
  @@index([attackerId])
  @@index([branch])
  @@map("battle_rounds")
}

// ── Module ───────────────────────────────────

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  branch      Branch
  orderIndex  Int
  title       String
  description String
  questionIds String[] @db.Uuid

  progress UserModuleProgress[]

  @@unique([branch, orderIndex])
  @@map("modules")
}

// ── UserModuleProgress ───────────────────────

model UserModuleProgress {
  userId             String    @db.Uuid
  moduleId           String    @db.Uuid
  completedQuestions String[]  @default([]) @db.Uuid
  completedAt        DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@map("user_module_progress")
}

// ── AiDialogue ───────────────────────────────

model AiDialogue {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  topic      String
  messages   Json     @default("[]")
  tokenCount Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_dialogues")
}

// ── KnowledgeChunk ──────────────────────────

model KnowledgeChunk {
  id        String   @id @default(uuid()) @db.Uuid
  content   String
  source    String
  sourceUrl String?
  category  String
  topic     String
  branch    Branch
  metadata  Json     @default("{}")
  embedding Unsupported("vector(1536)")?
  createdAt DateTime @default(now())

  @@index([branch])
  @@index([category])
  @@index([topic])
  @@map("knowledge_chunks")
}

// ── Achievement ─────────────────────────────

model Achievement {
  id          String              @id @default(uuid()) @db.Uuid
  code        String              @unique // e.g. "first_win", "streak_7"
  name        String              // Отображаемое название
  description String              // Описание как получить
  icon        String              // Иконка (emoji или URL)
  category    AchievementCategory
  condition   Json                // { "type": "wins", "threshold": 1 }
  xpReward    Int                 @default(0)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())

  users UserAchievement[]

  @@index([category])
  @@index([isActive])
  @@map("achievements")
}

// ── UserAchievement ─────────────────────────

model UserAchievement {
  userId        String   @db.Uuid
  achievementId String   @db.Uuid
  progress      Int      @default(0) // Текущий прогресс к цели
  unlockedAt    DateTime? // null = ещё не разблокировано

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

// ── Referral ────────────────────────────────

model Referral {
  id         String   @id @default(uuid()) @db.Uuid
  referrerId String   @db.Uuid
  inviteeId  String   @unique @db.Uuid // One user can only be invited once
  xpRewarded Boolean  @default(false)
  createdAt  DateTime @default(now())

  referrer User @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  invitee  User @relation("invitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referrals")
}

// ── Analytics ──────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  type      String   // battle_started, battle_finished, answer_given, session_start, session_end, warmup_completed, etc.
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ── Daily Challenge ────────────────────────

model DailyChallenge {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  date        String     // YYYY-MM-DD (UTC)
  difficulty  Difficulty
  branch      Branch
  category    String
  questionIds Json       // UUID[] of questions
  answers     Json?      // { questionId, selectedIndex, correct }[]
  correct     Int?
  total       Int?
  xpEarned    Int        @default(0)
  completedAt DateTime?
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_challenges")
}

// ── Daily Fact ─────────────────────────────

model DailyFact {
  id        String   @id @default(uuid()) @db.Uuid
  text      String
  source    String?  // Источник факта
  branch    Branch
  category  String
  isActive  Boolean  @default(true)
  usedAt    DateTime? @db.Date // Дата когда факт был показан
  createdAt DateTime @default(now())

  @@index([branch])
  @@index([isActive])
  @@index([usedAt])
  @@map("daily_facts")
}

// ── PushSubscription ─────────────────────────

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ── WarmupResult ──────────────────────────────

model WarmupResult {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  date         String   // YYYY-MM-DD (UTC)
  correctCount Int
  totalCount   Int
  timeTakenMs  Int?     // Total time taken in ms
  xpEarned     Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("warmup_results")
}

// ── AiTokenUsage (B17.4) ─────────────────────

model AiTokenUsage {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @db.Uuid
  date            String   // YYYY-MM-DD (UTC)
  model           String   // Model name (e.g. "gemini-2.5-flash")
  operation       String   // "dialogue", "question_generation", "explanation", "hint", "concept_extraction"
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([operation])
  @@index([userId, date])
  @@map("ai_token_usage")
}

// ── Tournament ──────────────────────────────

model Tournament {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  maxPlayers   Int              @default(8) // 8 or 16
  xpPrizePool  Int              @default(1000)
  status       TournamentStatus @default(REGISTRATION)
  bracket      Json             @default("[]") // Array of {round, match, player1Id, player2Id, winnerId}
  startsAt     DateTime
  createdAt    DateTime         @default(now())

  participants TournamentParticipant[]

  @@index([status])
  @@index([startsAt])
  @@map("tournaments")
}

model TournamentParticipant {
  id           String   @id @default(uuid()) @db.Uuid
  tournamentId String   @db.Uuid
  userId       String   @db.Uuid
  seed         Int?     // Seeding position (by rating)
  eliminated   Boolean  @default(false)
  placement    Int?     // Final placement (1st, 2nd, etc.)
  xpReward     Int      @default(0)
  joinedAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@map("tournament_participants")
}

enum TournamentStatus {
  REGISTRATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Bans ──────────────────────────────────────

model UserBan {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  reason    String
  type      BanType   @default(TEMPORARY)
  expiresAt DateTime?
  appealText  String?
  appealedAt  DateTime?
  appealStatus AppealStatus?
  issuedBy    String?   @db.Uuid
  liftedAt    DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_bans")
}

enum BanType {
  TEMPORARY
  PERMANENT
}

enum AppealStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Feed Card Types ──────────────────────────────

enum FeedCardType {
  INSIGHT
  CHALLENGE
  CASE
  SPARRING
  FORGE
  WISDOM
  ARENA
}

enum WarriorRank {
  NOVICE
  WARRIOR
  GLADIATOR
  STRATEGIST
  SPARTAN
}

// ── Campaign ──────────────────────────────────

model Campaign {
  id                    String      @id @default(uuid()) @db.Uuid
  title                 String
  description           String
  branch                Branch
  rank                  WarriorRank @default(NOVICE)
  durationDays          Int
  orderIndex            Int         @default(0)
  prerequisiteCampaignIds String[]  @default([]) @db.Uuid
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())

  cards    CampaignCard[]
  progress UserCampaignProgress[]

  @@unique([branch, orderIndex])
  @@index([branch])
  @@index([rank])
  @@index([isActive])
  @@map("campaigns")
}

// ── Campaign Card ─────────────────────────────

model CampaignCard {
  id          String       @id @default(uuid()) @db.Uuid
  campaignId  String       @db.Uuid
  dayNumber   Int          @db.SmallInt
  orderInDay  Int          @db.SmallInt
  type        FeedCardType
  content     Json         // Typed JSON matching FeedCardContent
  branch      Branch
  questionId  String?      @db.Uuid  // For CHALLENGE, SPARRING, FORGE types
  statPrimary String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  interactions FeedCardInteraction[]

  @@unique([campaignId, dayNumber, orderInDay])
  @@index([campaignId, dayNumber])
  @@index([type])
  @@map("campaign_cards")
}

// ── User Campaign Progress ────────────────────

model UserCampaignProgress {
  userId           String    @db.Uuid
  campaignId       String    @db.Uuid
  currentDay       Int       @default(1)
  completedCardIds String[]  @default([]) @db.Uuid
  streak           Int       @default(0)  // Days in a row in this campaign
  lastActiveDate   String?   // YYYY-MM-DD
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([userId, campaignId])
  @@index([userId])
  @@map("user_campaign_progress")
}

// ── User Feed State ───────────────────────────

model UserFeedState {
  userId             String   @id @db.Uuid
  activeCampaignIds  String[] @default([]) @db.Uuid
  todayCards         Json     @default("[]")  // Generated feed for today
  forgeQueue         Json     @default("[]")  // SRS queue: {questionId, nextReviewDate, attempt}[]
  feedStreak         Int      @default(0)
  lastFeedDate       String?  // YYYY-MM-DD
  todayViewedCount   Int      @default(0)
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_feed_state")
}

// ── Feed Card Interaction ─────────────────────

model FeedCardInteraction {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  cardId           String   @db.Uuid
  campaignId       String?  @db.Uuid
  type             String   // VIEWED, ANSWERED_CORRECT, ANSWERED_WRONG, SKIPPED, ARENA_CLICKED
  answerIndex      Int?     @db.SmallInt
  timeTakenMs      Int?
  xpEarned         Int      @default(0)
  createdAt        DateTime @default(now())

  card CampaignCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([cardId])
  @@index([campaignId])
  @@map("feed_card_interactions")
}

// ── Webhooks ──────────────────────────────────

model WebhookEndpoint {
  id        String   @id @default(uuid()) @db.Uuid
  url       String
  events    Json     @default("[]")
  secret    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id         String   @id @default(uuid()) @db.Uuid
  endpointId String   @db.Uuid
  event      String
  payload    Json
  statusCode Int
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}
